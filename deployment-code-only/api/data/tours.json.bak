    "activities": [],
    "itinerary": [
      {
        "day": 1,
        "title": "Arrive at Kathmandu",
        "description": "Upon your arrival at Kathmandu Airport, our representative will be there to welcome you and provide assistance after you\u2019ve completed the customs and immigration formalities. You will then be transferred to your hotel for check-in. In your evening, you\u2019ll attend the spiritual Aarti ceremony at the scared Pashupatinath Temple. Overnight stay will be at your hotel Kathmandu.",
        "accommodation": "3-Star Hotel",
        "meals": "N/A"
      },
      {
        "day": 2,
        "title": "Kathmandu Drive to Pokhara via Manakamana Cable Car 8-9Hrs)",
        "description": "After breakfast, begin your scenic drive to Pokhara, covering a distance of approximately 219 km. En- route enjoy a visit to the sacred Manakama Temple, accessible via an exciting cable car ride offering beautiful views. After the temple visit, continue your journey to Pokhara. Upon arrival, you\u2019ll be transferred to your hotel for check-in. Overnight stay at your hotel in Pokhara.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 3,
        "title": "Sunrise with Pumdikot Temple & Pokhara Sightseeing",
        "description": "Early in the morning, drive to Sarangkot hills to witness a breathtaking sunrise and panoramic views of the Himalayan range (weather permitting). Return to the hotel for breakfast. Later, set out for a full day sightseeing tour of Pokhara, including a visit to the Bindavasini temple (dedicated to Goddess Durga), Devi\u2019s waterfall, Gupteshwor Mahadev Cave, and Seti River Gorge. Enjoy a relaxing one-hour boat ride on the serene Phewa Lake, including a visit to the island temple of Tal Barahi. Overnight stay at your hotel in Pokhara.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 4,
        "title": "Pokhara \u2013 drive to Chitwan (about 160 km 5-6Hrs drive)",
        "description": "After breakfast, depart for Chitwan and enjoy the scenic drive through the countryside. Upon arrival, check in your hotel, where lunch will be served. In the afternoon, explore a traditional Tharu village to learn about the local culture and way of life. In the evening, witness a beautiful sunset followed by a lively Tharu cultural performance featuring the traditional stick dance. Overnight in Chitwan.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 5,
        "title": "Chitwan safari drive back to Katmandu",
        "description": "After breakfast, set out for an exciting Jeep Safari in Chitwan National Park, where you\u2019ll have the chance to spot diverse wildlife in their natural habitat. After the safari, return to the hotel and prepare for your drive to Kathmandu. Upon arrival in Kathmandu, enjoy some free time for shopping at the vibrant Thamel Market at your own pace. Later, check in to your hotel. Overnight stay at your hotel in Kathmandu.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 6,
        "title": "Kathmandu Sightseeing and departure",
        "description": "After breakfast sightseeing of Kathmandu Valley including Boudhanath Stupa, Jala Temple (Sleeping Vishnu), Swyambhunath Stupa (Monkey temple) and Kathmandu Durbar Square (Living God Kumari). Then you will be transferred to the Airport in time.",
        "accommodation": "N/A",
        "meals": "Breakfast"
      }
