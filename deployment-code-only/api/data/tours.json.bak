    "id": 306,
    "slug": "indo-nepal-cross-border-tour-6n-7d",
    "title": "Indo Nepal Cross Border Tour - 6 Nights 7 Days",
    "category": "Cultural",
    "description": "Experience the best of Nepal with this comprehensive cross-border tour covering Pokhara's natural beauty, Kathmandu's cultural heritage, and Chitwan's wildlife adventure. This unique journey starts from Gorakhpur, India, and takes you through the sacred birthplace of Lord Buddha in Lumbini, the serene lakes of Pokhara, the ancient temples of Kathmandu, and the wildlife paradise of Chitwan National Park.",
    "location": "Nepal",
    "price": 0,
    "duration": "7 days",
    "group_size": "2-15 people",
    "difficulty": "Easy",
    "rating": 4.5,
    "reviews": 89,
    "best_time": "October-April",
    "featured": false,
    "listed": true,
    "image": "/uploads/tours/indo-nepal-cross-border-tour-6n-7d/tour_1766899314464.webp",
    "gallery": [],
    "highlights": [
