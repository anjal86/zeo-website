    "itinerary": [
      {
        "day": 1,
        "title": "Arrival in Bangkok",
        "description": "Arrive at Bangkok International Airport, where our representative will warmly welcome you and assist with your transfer to the hotel. After check-in, take time to relax and recover from your journey. You may explore nearby markets, enjoy Thai street food, or simply unwind at the hotel. Bangkok\u2019s vibrant atmosphere, colorful streets, and friendly locals provide a perfect introduction to Thailand. Overnight stay in Bangkok.",
        "accommodation": "3-Star Hotel             ",
        "meals": "N/A"
      },
      {
        "day": 2,
        "title": "Flight to Phuket | Arrival & Transfer",
        "description": "After breakfast, transfer to the airport for your domestic flight to Phuket. On arrival, meet our local representative and proceed to your hotel. Check in and enjoy the rest of the day at leisure. You can relax on the beach, explore Patong\u2019s lively streets, or enjoy optional activities. Phuket\u2019s tropical charm sets the mood for an island holiday. Overnight stay in Phuket.",
        "accommodation": "3-Star Hotel          ",
        "meals": "Breakfast"
      },
      {
        "day": 3,
        "title": "Full-Day Phi Phi Island Tour with Lunch.",
        "description": "Today, enjoy a full-day excursion to the world-famous Phi Phi Islands. Cruise through turquoise waters, admire dramatic limestone cliffs, and visit stunning locations such as Maya Bay and Phi Phi Don. Enjoy swimming, snorkeling, and relaxing on pristine beaches. A delicious lunch is included during the tour. Return to Phuket in the evening with unforgettable island memories.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast & Lunch"
      },
      {
        "day": 4,
        "title": "Transfer from Phuket to Krabi",
        "description": "After breakfast, check out from the hotel and proceed towards Krabi by comfortable transfer. Enjoy scenic views along the way as you move from one tropical paradise to another. Upon arrival, check in at your hotel and relax. The remainder of the day is free to explore nearby beaches or enjoy Krabi\u2019s calm and scenic surroundings. Overnight stay in Krabi.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 5,
        "title": "Full-Day Four Island Tour with Lunch (Krabi)",
        "description": "Set out for a full-day Four Island tour, visiting some of Krabi\u2019s most beautiful islands including Poda Island, Chicken Island, Tup Island, and Phra Nang Cave Beach. Enjoy snorkeling, swimming, and relaxing on white sandy beaches. A tasty lunch is provided during the tour. Return to your hotel by evening for rest and relaxation.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 6,
        "title": "Flight to Bangkok | Evening Dinner Cruise",
        "description": "After breakfast, transfer to the airport for your flight back to Bangkok. Upon arrival, check in to your hotel and relax. In the evening, enjoy a memorable dinner cruise along the river, featuring delicious cuisine, live entertainment, and stunning night views of Bangkok\u2019s illuminated landmarks. Overnight stay in Bangkok.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 7,
        "title": "Safari World & Marine Park",
        "description": "After breakfast, proceed for a full-day visit to Safari World and Marine Park. Enjoy close encounters with wildlife, exciting safari drives, and entertaining animal shows. This fun-filled experience is ideal for families and nature lovers. After a day of adventure, return to the hotel for a restful evening. Overnight stay in Bangkok.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 8,
        "title": "Departure",
        "description": "After breakfast, check out from the hotel and transfer to the airport for your onward journey. Depart Thailand with beautiful memories of its vibrant cities, breathtaking islands, rich culture, and warm hospitality, bringing an unforgettable holiday experience to a perfect conclusion.",
        "accommodation": "N/A",
        "meals": "Breakfast"
      }
