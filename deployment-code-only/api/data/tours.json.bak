  {
    "slug": "kailash-mansarovar-yatra-ex-lhasa-10-nights-11-days-",
    "title": "Kailash Mansarovar Yatra Ex Lhasa - 10 Nights 11 Days ",
    "description": "Experience a sacred and life-changing pilgrimage to Mount Kailash and Lake Mansarovar starting from Lhasa. This spiritual journey includes acclimatization and sightseeing in Lhasa, a scenic drive across the Tibetan Plateau, a holy dip at Lake Mansarovar, and the divine Parikrama of Mount Kailash. Carefully organized with experienced guides, permits, and best available accommodations, this yatra offers a safe, meaningful, and unforgettable spiritual experience.",
    "price": 0,
    "duration": "11 days",
    "group_size": "",
    "best_time": "",
    "image": "/uploads/tours/kailash-mansarovar-yatra-ex-lhasa-10-nights-11-days-/tour_1766141032912.webp",
