  {
    "slug": "nepal-tour-4nights-5days-",
    "title": "Nepal Tour 4Nights 5Days ",
    "description": "Discover the cultural heart and scenic beauty of Nepal with this Kathmandu & Nagarkot Tour. Explore Kathmandu\u2019s UNESCO World Heritage Sites, ancient temples, and vibrant local markets that reflect the city\u2019s rich history and spiritual traditions. From sacred shrines to historic palace squares, Kathmandu offers a fascinating blend of culture and heritage.\nEscape to Nagarkot, a peaceful hill station renowned for its breathtaking sunrise and panoramic Himalayan views. Surrounded by lush hills and fresh mountain air, Nagarkot is the perfect retreat for relaxation and photography, offering unforgettable vistas of snow-capped peaks in a serene natural setting.",
    "price": 0,
    "duration": "5 days",
    "group_size": "2-8 people",
    "best_time": "",
    "image": "/uploads/tours/nepal-tour-4nights-5days-/tour_1766900758861.jpg",
    "gallery": [],
    "highlights": [],
    "inclusions": [],
    "exclusions": [],
    "activities": [],
