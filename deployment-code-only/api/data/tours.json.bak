  {
    "id": 7,
    "slug": "kathmandu-pokhara-muktinath-7n-8d",
    "title": "Kathmandu, Pokhara & Muktinath-7N/8D",
    "category": "Cultural",
    "description": "This 8-day divine pilgrimage journey blends sacred devotion with Nepal\u2019s breathtaking landscapes and cultural heritage. Starting in Kathmandu with the holy aarti at Pashupatinath, the tour leads through Pokhara and Jomsom to the revered Muktinath Temple, a powerful center of liberation and faith. Enriched with Himalayan sunrises, tranquil temple visits, and UNESCO heritage sites, this journey offers a deeply soul-enriching experience for pilgrims seeking peace, blessings, and spiritual fulfillment.",
    "location": "Pokhara",
    "price": 0,
    "duration": "8 days",
    "group_size": "2-12 people",
    "difficulty": "Easy",
    "rating": 4.364871682579423,
    "reviews": 179,
    "best_time": "March-May, September-November",
    "featured": false,
    "listed": true,
