    "activities": [],
    "itinerary": [
      {
        "day": 1,
        "title": "Arrival at Airport & Fly to Pokhara",
        "description": "Journey begins rights at Kathmandu Tribhuvan International Airport, where our representative will assist you. Take a domestic flight from Kathmandu to Pokhara (25-30 minutes). Once you arrive at Pokhara airport you will be taken to comfortable Hotel. In evening enjoy Phewa Lake views. (one hour boat ride). Return to hotel. Overnight at Pokhara Hotel.",
        "accommodation": "3-Star Hotel ",
        "meals": "Dinner"
      },
      {
        "day": 2,
        "title": "Pokhara \u2013 Drive to Nayapul \u2013 Trek to Ghandruk",
        "description": "In the morning, drive about 1.5 hours to Nayapul, then begin a 4-5 hours trek to Ghandruk. The routes passes through beautiful villages like Kimche and Syauli Bazaar. Once in Ghandruk, enjoy views of Annapurna South, Machhapuchhre, and visit the Gurung Museum. Stay overnight in a local teahouse or mountain lodge.",
        "accommodation": "Lodge",
        "meals": "Breakfast & Dinner"
      },
      {
        "day": 3,
        "title": "Ghandruk Exploration Day",
        "description": "Start your morning with a stunning sunrise view over the snow-covered peaks. Today is a relaxed day in Ghandruk, allowing you to explore at your own pace. Walk through terrace fields, or simply spend time with local to understand rural mountain life. Take a short nature walk to nearby ridges or views point for photography. Return to your teahouse for a warm dinner. Overnight in Ghandruk.",
        "accommodation": "Lodge   ",
        "meals": "Breakfast & Dinner"
      },
      {
        "day": 4,
        "title": "Ghandruk \u2013 Trek back to Nayapul \u2013 Drive back to Pokhara",
        "description": "After breakfast, begin your 3-4 hours downhill trek back to Nayapul. The return is easier and offers a chance to revisit the beautiful landscapes in a more relaxed way. Once you reach Nayapul, your vehicle will drive you back to Pokhara. Check-in to your hotel spent your afternoon visiting local attractions like Devi\u2019s Falls, Gupteshwor Mahadev Cave, or world Peace Pagoda. Return back to hotel. Overnight stay in Pokhara.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast & Dinner"
      },
      {
        "day": 5,
        "title": "Pokhara \u2013 Fly back to Kathmandu",
        "description": "Early morning return back to Kathmandu by flight. Visit Swoyambhunath Stupa (Monkey Temple) and Kathmandu Durbar Square (living God Kumari). Attend Pashupatinath temple for aarti. ",
        "accommodation": "N/A",
        "meals": "Breakfast"
      }
    ],
