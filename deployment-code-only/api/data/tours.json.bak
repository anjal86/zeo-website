      {
        "day": 1,
        "title": "Arrival in Da Nang",
        "description": "Arrive at Da Nang International Airport and transfer to your hotel. After check-in, enjoy free time at leisure to relax or explore the city on your own. Overnight stay in Da Nang.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 2,
        "title": "Da Nang \u2013 Ba Na Hills & Golden Bridge",
        "description": "After breakfast, travel to Ba Na Hills and enjoy a scenic cable car ride. Visit the iconic Golden Bridge, flower gardens, pagodas, French Village, and Fantasy Park. Return to Da Nang in the evening for overnight stay.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 3,
        "title": "Da Nang City Tour \u2013 Marble Mountains \u2013 Hoi An Ancient Town",
        "description": "Explore Da Nang\u2019s city highlights including Son Tra Peninsula, Lady Buddha, and My Khe Beach. Continue to Marble Mountains and Coconut Village for a bamboo basket boat experience. In the evening, visit Hoi An Ancient Town and enjoy a lantern boat ride. Overnight stay in Da Nang.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 4,
        "title": "Da Nang \u2013 Flight to Hanoi \u2013 City Tour",
        "description": "After breakfast, fly to Hanoi and check in at the hotel. Visit major attractions including the Ho Chi Minh Complex, One Pillar Pagoda, Hoan Kiem Lake, and the Old Quarter. Enjoy free time in the evening. Overnight stay in Hanoi.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 5,
        "title": "Hanoi \u2013 Halong Bay Day Cruise",
        "description": "Travel to Halong Bay for a scenic day cruise through limestone islands. Visit caves, enjoy a seafood lunch on board, and admire the natural beauty of this UNESCO World Heritage Site before returning to Hanoi for overnight stay.",
