    ],
    "activities": [],
    "itinerary": [
      {
        "day": 1,
        "title": "Arrival in Beijing Airport | Transfer to Hotel",
        "description": "Upon arrival at Beijing Airport, you will be warmly welcomed and transferred to hotel. After check-in, enjoy some leisure time to rest or explore the nearby surrounding area at your own pace.",
        "accommodation": "3-Star Hotel",
        "meals": "N/A"
      },
      {
        "day": 2,
        "title": "Beijing City Tour (Tiananmen Square, Forbidden City, Temple of Heaven)",
        "description": "After breakfast, start with a visit to Tiananmen Square, the heart of Beijing and one of the largest public squares in the world. From there, walk into the grand Forbidden City (Palace Museum), the spectacular imperial palace that was home to China\u2019s emperors for over 500 years. Later, visit the Temple of Heaven, a masterpiece of Ming and Qing architecture where emperors once performed solemn rituals to pray for good harvests, offering a tranquil contrast to the bustling city.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 3,
        "title": "Great wall of China | Outside View of bird nest",
        "description": "After breakfast, set out to visit one of the world\u2019s greatest wonders; the Great Wall at Juyong Pass. Stroll along the ancient ramparts, capture stunning photos, and admire the breathtaking mountain scenery. On your return journey, make a brief stop for an outside view of the Bird\u2019s Nest (Beijing National Stadium), the architectural marvel of the 2008 Olympics. In the afternoon, browse a local market to enjoy some shopping and local interactions.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 4,
        "title": "Beijing to Shanghai by High-speed Bullet Train",
        "description": "After breakfast, check out and transfer to the station to board a high-speed bullet train to Beijing, offering a scenic and comfortable ride through the Chinese countryside. Upon arrival in Beijing, transfer to your hotel. Spend the rest of the day at leisure, settling in and preparing for your exploration of the Capital.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 5,
        "title": "Shanghai Highlights (Jade Buddha Temple, Yu Market, The Bund, Xintiandi, Nanjing Road) ",
        "description": "After breakfast, begin your Shanghai city tour with a visit to the peaceful Jade Buddha Temple, famous for its exquisite jade Buddha statues. Continue to the Yu Garden Bazaar, a lively marketplace surrounded by traditional architecture where you can shop for souvenirs and local snacks. Later, stroll along The Bund, Shanghai\u2019s iconic waterfront, renowned for its colonial-era buildings and spectacular skyline views across the Huangpu River. In the evening, explore. Xintiandi, a stylish district blending old Shikumen houses with trendy restaurants and boutiques. Finally, enjoy a walk down the bustling Nanjing Road, Shanghai\u2019s premier shopping avenue, before returning to your hotel.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 6,
        "title": "Departure",
        "description": "After breakfast you will be transfer to Airport according to your flight time.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      }
    ],
