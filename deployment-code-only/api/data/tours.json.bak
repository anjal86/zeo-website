    "activities": [],
    "itinerary": [
      {
        "day": 1,
        "title": "Arrive in Kathmandu",
        "description": "Upon arrival in Kathmandu Airport, you will be greeted and assisted by our representative after completing your custom formalities, transfer to the hotel for check-in. And evening attended Aarti at Pashupatinath Temple overnight at Kathmandu hotel.",
        "accommodation": "3-Star Hotel",
        "meals": "N/A"
      },
      {
        "day": 2,
        "title": "Kathmandu City Sightseeing",
        "description": "After breakfast Kathmandu city sightseeing tour, Jala Narayan Temple (Sleeping Vishnu), Swoyambhunath Stupa (Monkey Temple), Boudhanath Stupa (World heritage site) & Kathmandu Durbar Square (Living God Kumari) drive back to hotel. Overnight is at a hotel in Kathmandu.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 3,
        "title": "Kathmandu to Pokhara (6-8 Hours)",
        "description": "After breakfast, drive from Kathmandu to Pokhara via the scenic Prithvi highway. On arrival, visit Tal Barahi Temple. Return to the hotel. Evening free for shopping. Overnight in Pokhara.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 4,
        "title": "Sunrise Sarangkot & Pokhara sightseeing",
        "description": "Early morning 5AM drive to Pumdikot Temple enjoy with sunrise and Panoramic Mountain View from Pumdikot (Mountain view depends on whether) After That visit to David water falls, Gupteshwor Mahadev Cave, Back to Hotel, take breakfast, later visit to Bindabasini Temple (Durga Temple), Seti River Gorge, and one hour boat ride on Phewa Lake and visit Tal Barahi Temple, later drive back to hotel. Overnight at a hotel in Pokhara.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 5,
        "title": "Pokhara to Kathmandu (6-8 hour)",
        "description": "After breakfast, begin your return journey from Pokhara to Kathmandu by road, a scenic drive of around 6-8 hours along the Prithvi Highway. The route passes through charming towns like Damauli Mugling and Kurintar, with views of rivers, hills, and rural life along the way. You can stop for lunch or short breaks at local roadside restaurants. Arrive in Kathmandu by late afternoon or evening and transfer to your hotel.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 6,
        "title": "Kathmandu Sightseeing drive to Nagarkot (About 26 km, 1& half hours\u2019 Drive)",
        "description": "After having a leisurely breakfast drive to visit Bhaktapur Durbar Square (World heritage site), Doleshwar Mahadev (Head of Kedarnath Temple) & Kailashnath Mahadev (103 ft. statue of lord Shiva) later drive to Nagarkot upon arrival in Nagarkot transfer to hotel for check-in. Evening Watch sunset from hotel Room balcony. Overnight in at a Hotel in Nagarkot.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 7,
        "title": "Nagarkot- departure transfer",
        "description": "Early morning enjoy sunrise from room balcony and panoramic Mountain View Subject to Weather Condition later take breakfast, after breakfast the morning will be comparatively free and closer to the time of your flight, you will be transferred to airport in time to board your flight for onward journey.",
        "accommodation": "N/A",
        "meals": "Breakfast"
      }
    ],
