    "activities": [],
    "itinerary": [
      {
        "day": 1,
        "title": "Arrival at the Airport & Free Day",
        "description": "Upon arrival at Bali Airport, you will be warmly welcomed and transferred to your hotel in a private vehicle. After check-in, take time to relax and unwind after your journey. You may explore nearby streets, enjoy the local ambiance, or simply rest in your comfortable hotel. This day is designed to help you acclimatize and prepare for the exciting Bali experiences ahead. Overnight stay at the hotel.",
        "accommodation": "3-Star Hotel",
        "meals": "N/A"
      },
      {
        "day": 2,
        "title": "Denpasar City Tour & Ubud Exploration",
        "description": "After breakfast, start with Bajra Sandi Monument, honoring Balinese history. Explore the Bali Museum, home to artefacts, paintings, bronze-age weapons, and musical instruments. Visit Celuk Village, renowned for silver and gold handicrafts, and witness artisans at work. Continue to Ubud, the cultural heart of Bali, and explore Ubud Market, filled with local crafts, textiles, and souvenirs. Return to the hotel for an overnight stay.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 3,
        "title": "Tanah LotTemple, Uluwatu & Jimbaran Bay with Seafood Dinner",
        "description": "Uluwatu temple: Built on the top of a cliff about 825 feet high facing the vast deep blue Indian Ocean also offers a wonderful view of the sunset. You will also meet lots of monkeys here. The view of ocean from Uluwatu is just enchanting.\nTanah Lot: A spectacular temple built in the 17th century, on top of rock about 200 meters offshore. The whole compound will turn into a wonderful silhouette as the sunset right behind the temple, one of the most photographed temples on the island - for good reason. The perfect combo of rustling of the waves, the sun and the temple leaves you with positive energy. You can also buy souvenirs here, they have varieties of Balinese crafts, linen and arts.\nJimbaran Bay with Sea Food: In the evening, proceed to Jimbaran Bay for a delightful seafood dinner with a beautiful ocean view. Return to your hotel for an overnight stay.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 4,
        "title": "Free Day for Leisure & Exploration",
        "description": "Enjoy a full day at your own pace. Explore Bali\u2019s streets, shops, art galleries, or caf\u00e9s, or relax on its beautiful beaches. Optional activities include water sports, spa treatments, or cultural performances. Capture memories of Bali\u2019s lush landscapes, rice terraces, and vibrant culture. Return to your hotel for an overnight stay.",
        "accommodation": "3-Star Hotel",
        "meals": "Breakfast"
      },
      {
        "day": 5,
        "title": "Departure",
        "description": "After breakfast, check out and transfer to Bali Airport for your departure. Take home unforgettable memories of Bali\u2019s temples, culture, scenic beauty, and warm hospitality, concluding your luxurious island getaway.",
        "accommodation": "N/A",
        "meals": "Breakfast"
      }
