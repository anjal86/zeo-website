# Copy this file to .env and fill in real values before deploying to production.

# Server
PORT=3000
NODE_ENV=production

# JWT — use a long, random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace-with-a-long-random-secret

# Admin credentials
# To use a bcrypt hash for ADMIN_PASSWORD, generate one with:
#   node -e "const bcrypt=require('bcrypt'); bcrypt.hash('yourpassword',12).then(console.log)"
ADMIN_EMAIL=admin@zeotourism.com
ADMIN_PASSWORD=replace-with-secure-password-or-bcrypt-hash
