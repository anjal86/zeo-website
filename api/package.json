{
  "name": "zeopwebsite-deployment",
  "version": "1.0.0",
  "description": "Zeo Tourism Website - Production Deployment (JSON-based)",
  "main": "server.js",
  "scripts": {
    "start": "node -r ./runtime/logging-bootstrap.js -r ./security-bootstrap.js server.js",
    "start:unsafe-dev": "node server.js",
    "install-deps": "npm ci --omit=dev",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:test": "node --test test/*.test.js",
    "test": "node --test test/*.test.js",
    "backup:changed": "node scripts/incremental-backup.js",
    "backup:changed:cron": "bash scripts/run-incremental-backup.sh",
    "backup:verify": "node scripts/verify-backup-health.js"
  },
  "dependencies": {
    "@vercel/blob": "^2.6.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.5",
    "sharp": "^0.32.6"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "keywords": [
    "tourism",
    "travel",
    "nepal",
    "tours",
    "website",
    "json-api"
  ],
  "author": "Zeo Tourism",
  "license": "MIT"
}
