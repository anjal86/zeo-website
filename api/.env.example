# Copy this file to .env and fill in real values before deploying to production.

# Server
PORT=3000
NODE_ENV=production

# JWT — use a long, random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace-with-a-long-random-secret

# Admin credentials
# To use a bcrypt hash for ADMIN_PASSWORD, generate one with:
#   node -e "const bcrypt=require('bcrypt'); bcrypt.hash('yourpassword',12).then(console.log)"
ADMIN_EMAIL=admin@zeotourism.com
ADMIN_PASSWORD=replace-with-secure-password-or-bcrypt-hash

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=zeo_user
DB_PASSWORD=replace-with-mysql-password
DB_NAME=zeo_website

# Incremental backup to S3-compatible R3/R2 storage
# Run manually with: npm run backup:changed
# Schedule daily using cron: 15 2 * * * cd /var/www/zeo/api && npm run backup:changed:cron
BACKUP_BUCKET=replace-with-bucket-name
BACKUP_ENDPOINT_URL=https://replace-with-account-or-s3-endpoint
BACKUP_REGION=auto
BACKUP_ACCESS_KEY_ID=replace-with-access-key
BACKUP_SECRET_ACCESS_KEY=replace-with-secret-key
BACKUP_PREFIX=zeo/incremental
BACKUP_S3_FORCE_PATH_STYLE=true
BACKUP_UPLOAD_DIRS=uploads
BACKUP_DB_TIMESTAMP_COLUMNS=updated_at,created_at,updatedAt,createdAt
# Optional: comma-separate specific tables. Leave blank to auto-scan all tables.
BACKUP_DB_TABLES=
# Optional: set true to verify scan/compression without uploading.
BACKUP_DRY_RUN=false
