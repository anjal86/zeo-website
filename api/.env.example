# Copy this file to .env and replace every placeholder before production.

# Server
PORT=3000
NODE_ENV=production
PUBLIC_SITE_URL=https://zeotourism.com
CORS_ALLOWED_ORIGINS=https://zeotourism.com,https://www.zeotourism.com
CORS_ALLOW_NO_ORIGIN=true
TRUST_PROXY_HOPS=1
REQUEST_TIMEOUT_MS=30000
JSON_BODY_LIMIT=250kb
FORM_BODY_LIMIT=250kb

# JWT
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-at-least-64-random-characters
JWT_ISSUER=zeotourism-api
JWT_AUDIENCE=zeotourism-admin
JWT_EXPIRES_IN=60m

# Admin credentials
# ADMIN_PASSWORD must be a bcrypt hash. Generate it from api/ with:
# node -e "const bcrypt=require('bcrypt'); bcrypt.hash(process.argv[1],12).then(console.log)" 'YOUR-NEW-PASSWORD'
ADMIN_EMAIL=replace-with-private-admin-email
ADMIN_PASSWORD=$2b$12$replace-with-a-real-bcrypt-hash

# MySQL — use a dedicated least-privilege database account
DB_HOST=localhost
DB_PORT=3306
DB_USER=zeo_app
DB_PASSWORD=replace-with-a-long-random-database-password
DB_NAME=zeo_website
DB_CONNECTION_LIMIT=10

# Optional private Vercel Blob proxy. Both values are required when enabled.
BLOB_PUBLIC_BASE_URL=https://replace-with-your-store.public.blob.vercel-storage.com
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token
BLOB_PROXY_MAX_BYTES=26214400

# Incremental backup to S3-compatible R2/S3 storage
# Run manually with: npm run backup:changed
# Schedule daily using cron: 15 2 * * * cd /var/www/zeo/api && npm run backup:changed:cron
BACKUP_BUCKET=replace-with-bucket-name
BACKUP_ENDPOINT_URL=https://replace-with-account-or-s3-endpoint
BACKUP_REGION=auto
BACKUP_ACCESS_KEY_ID=replace-with-access-key
BACKUP_SECRET_ACCESS_KEY=replace-with-secret-key
BACKUP_PREFIX=zeo/incremental
BACKUP_S3_FORCE_PATH_STYLE=true
BACKUP_UPLOAD_DIRS=uploads
BACKUP_DB_TIMESTAMP_COLUMNS=updated_at,created_at,updatedAt,createdAt
# Optional: comma-separate specific tables. Leave blank to auto-scan all tables.
BACKUP_DB_TABLES=
# Optional: set true to verify scan/compression without uploading.
BACKUP_DRY_RUN=false
