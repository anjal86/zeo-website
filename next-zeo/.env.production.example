# =============================================================================
# ZEO WEBSITE - PRODUCTION ENVIRONMENT
# =============================================================================
NODE_ENV=production
APP_URL=https://zeotourism.com

# MySQL Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=zeo_prod
MYSQL_PASSWORD=change-this-to-strong-password
MYSQL_DATABASE=zeo_website
MYSQL_CONNECTION_LIMIT=10

# Admin Session
JWT_SECRET=change-this-to-64-char-random-string
ADMIN_EMAIL=admin@zeotourism.com
ADMIN_PASSWORD=change-me

# Storage
STORAGE_DRIVER=local
UPLOAD_DIR=/var/www/zeo/uploads

# Optional S3
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=
