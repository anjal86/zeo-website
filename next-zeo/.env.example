NODE_ENV=development
APP_URL=http://localhost:3000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=zeo_user
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=zeo_website
MYSQL_CONNECTION_LIMIT=10

JWT_SECRET=change-me-long-random-session-secret
ADMIN_EMAIL=admin@zeotourism.com
ADMIN_PASSWORD=change-me

UPLOAD_DIR=/var/www/zeo/uploads
STORAGE_DRIVER=local

# Google Search Console service account used by the admin SEO Manager.
# The service account must be added to the configured Search Console property.
GOOGLE_SEARCH_CONSOLE_CLIENT_EMAIL=
GOOGLE_SEARCH_CONSOLE_PRIVATE_KEY=
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:zeotourism.com

# Optional S3-compatible storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
