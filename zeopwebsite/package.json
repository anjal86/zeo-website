{
  "name": "zeopwebsite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "npm run generate-sitemap && tsc -b && vite build && npm run prerender:seo",
    "build:no-sitemap": "tsc -b && vite build && npm run prerender:seo",
    "generate-sitemap": "node scripts/generateSitemap.cjs && node scripts/generateLlms.cjs",
    "prerender:seo": "node scripts/prerenderStatic.cjs",
    "sitemap:monitor": "node scripts/autoSitemapUpdate.cjs --monitor",
    "sitemap:webhook": "node scripts/autoSitemapUpdate.cjs --webhook",
    "sitemap:once": "node scripts/autoSitemapUpdate.cjs --once",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/jspdf": "^1.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "country-list": "^2.4.1",
    "framer-motion": "^12.23.12",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.541.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.5.0",
    "react-quill-new": "^3.7.0",
    "react-router-dom": "^7.8.2",
    "swiper": "^11.2.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
