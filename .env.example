# =============================================================================
# ZEO WEBSITE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zeo_website
DB_USER=zeo_user
DB_PASSWORD=your_password_here
DB_POOL_SIZE=10

# Application Configuration
NODE_ENV=development
PORT=3000

# API Keys (if needed)
# API_KEY=your_api_key_here

# =============================================================================
# LOCAL DEVELOPMENT (Docker)
# =============================================================================
# These values work with docker-compose.yml
#
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=zeo_website
# DB_USER=root
# DB_PASSWORD=rootpassword

# =============================================================================
# CPANEL PRODUCTION
# =============================================================================
# Use your cPanel credentials:
#
# DB_HOST=localhost (or provided by host)
# DB_NAME=yourusername_zeo_website
# DB_USER=yourusername_zeo_user
# DB_PASSWORD=[generated in cPanel]
