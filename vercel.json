{
    "buildCommand": "cd zeopwebsite && npm run build && cp -r dist ../dist",
    "outputDirectory": "dist",
    "installCommand": "npm install --prefix zeopwebsite && npm install --prefix api",
    "headers": [
        {
            "source": "/assets/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/plain; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600"
                }
            ]
        },
        {
            "source": "/sitemap.xml",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/xml; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/robots.txt",
            "destination": "/robots.txt"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/sitemap.xml"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/server"
        },
        {
            "source": "/uploads/:path*",
            "destination": "/api/server"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
